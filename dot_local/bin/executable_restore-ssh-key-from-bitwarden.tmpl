#!/bin/sh
# 从 Bitwarden 恢复 ed25519 SSH 私钥到本机 ~/.ssh 目录。

set -eu

item_name='{{ .bitwarden.items.ssh_ed25519 }}'
target="${HOME}/.ssh/id_ed25519"

if ! command -v bw >/dev/null 2>&1; then
  echo "restore-ssh-key: bw 未安装" >&2
  exit 1
fi

ensure_bw_session() {
  if [ -n "${BW_SESSION:-}" ]; then
    return
  fi

  status="$(bw status 2>/dev/null || true)"
  case "$status" in
    *'"status":"unlocked"'*)
      return
      ;;
    *'"status":"unauthenticated"'*)
      if [ -t 2 ]; then
        bw login </dev/tty >/dev/tty 2>/dev/tty || true
      fi
      ;;
  esac

  status="$(bw status 2>/dev/null || true)"
  case "$status" in
    *'"status":"unlocked"'*)
      return
      ;;
    *'"status":"locked"'*|*'"status":"unauthenticated"'*)
      if [ -t 2 ]; then
        BW_SESSION="$(bw unlock --raw </dev/tty 2>/dev/tty)"
        export BW_SESSION
        return
      fi

      echo "restore-ssh-key: Bitwarden 未解锁，且当前无法交互输入，请先手动执行 bw unlock 或设置 BW_SESSION" >&2
      exit 1
      ;;
  esac
}

ensure_bw_session

item_json="$(bw list items --search "$item_name" | jq -cer --arg name "$item_name" 'map(select(.name == $name))[0]')"
private_key="$(printf '%s' "$item_json" | jq -r '.notes')"

if [ -z "$private_key" ] || [ "$private_key" = "null" ]; then
  echo "restore-ssh-key: Bitwarden 条目 ${item_name} 不包含私钥内容" >&2
  exit 1
fi

mkdir -p "${HOME}/.ssh"
chmod 700 "${HOME}/.ssh"
umask 077
printf '%s\n' "$private_key" > "$target"
chmod 600 "$target"

if [ -f "${HOME}/.ssh/id_ed25519.pub" ]; then
  chmod 644 "${HOME}/.ssh/id_ed25519.pub"
fi

if command -v ssh-add >/dev/null 2>&1; then
{{- if eq .chezmoi.os "darwin" }}
  ssh-add --apple-use-keychain "$target" >/dev/null 2>&1 || true
{{- else }}
  ssh-add "$target" >/dev/null 2>&1 || true
{{- end }}
fi
