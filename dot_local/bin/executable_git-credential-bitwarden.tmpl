#!/bin/sh
# 通过 Bitwarden CLI 为 GitHub 提供 Git credential，避免把凭据写入本地明文文件。

set -eu

action="${1:-get}"
case "$action" in
  get)
    ;;
  store|erase)
    exit 0
    ;;
  *)
    exit 0
    ;;
esac

protocol=""
host=""

while IFS='=' read -r key value; do
  [ -z "${key}" ] && break
  case "$key" in
    protocol)
      protocol="$value"
      ;;
    host)
      host="$value"
      ;;
  esac
done

if [ "$protocol" != "https" ] || [ "$host" != "github.com" ]; then
  exit 0
fi

if ! command -v bw >/dev/null 2>&1; then
  echo "git-credential-bitwarden: bw 未安装" >&2
  exit 1
fi

if [ -z "${BW_SESSION:-}" ]; then
  echo "git-credential-bitwarden: BW_SESSION 未设置，请先执行 bw unlock --raw 并导出环境变量" >&2
  exit 1
fi

item_json="$(bw list items --search '{{ .bitwarden.items.github_pat }}' | jq -cer --arg name '{{ .bitwarden.items.github_pat }}' 'map(select(.name == $name and .login.username != null and .login.password != null))[0]')"

username="$(printf '%s' "$item_json" | jq -r '.login.username')"
password="$(printf '%s' "$item_json" | jq -r '.login.password')"

printf 'username=%s\n' "$username"
printf 'password=%s\n' "$password"
