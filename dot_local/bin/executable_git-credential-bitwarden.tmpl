#!/bin/sh
# 通过 Bitwarden CLI 为 GitHub 提供 Git credential，避免把凭据写入本地明文文件。

set -eu

action="${1:-get}"
case "$action" in
  get)
    ;;
  store|erase)
    exit 0
    ;;
  *)
    exit 0
    ;;
esac

protocol=""
host=""

while IFS='=' read -r key value; do
  [ -z "${key}" ] && break
  case "$key" in
    protocol)
      protocol="$value"
      ;;
    host)
      host="$value"
      ;;
  esac
done

if [ "$protocol" != "https" ] || [ "$host" != "github.com" ]; then
  exit 0
fi

if ! command -v bw >/dev/null 2>&1; then
  echo "git-credential-bitwarden: bw 未安装" >&2
  exit 1
fi

ensure_bw_session() {
  if [ -n "${BW_SESSION:-}" ]; then
    return
  fi

  status="$(bw status 2>/dev/null || true)"
  case "$status" in
    *'"status":"unlocked"'*)
      return
      ;;
    *'"status":"unauthenticated"'*)
      if [ -t 2 ]; then
        bw login </dev/tty >/dev/tty 2>/dev/tty || true
      fi
      ;;
  esac

  status="$(bw status 2>/dev/null || true)"
  case "$status" in
    *'"status":"unlocked"'*)
      return
      ;;
    *'"status":"locked"'*|*'"status":"unauthenticated"'*)
      if [ -t 2 ]; then
        BW_SESSION="$(bw unlock --raw </dev/tty 2>/dev/tty)"
        export BW_SESSION
        return
      fi

      echo "git-credential-bitwarden: Bitwarden 未解锁，且当前无法交互输入，请先手动执行 bw unlock 或设置 BW_SESSION" >&2
      exit 1
      ;;
  esac
}

ensure_bw_session

item_json="$(bw list items --search '{{ .bitwarden.items.github_pat }}' | jq -cer --arg name '{{ .bitwarden.items.github_pat }}' 'map(select(.name == $name and .login.username != null and .login.password != null))[0]')"

username="$(printf '%s' "$item_json" | jq -r '.login.username')"
password="$(printf '%s' "$item_json" | jq -r '.login.password')"

printf 'username=%s\n' "$username"
printf 'password=%s\n' "$password"
